# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API (optional — used by legacy apiClient)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_V1_PREFIX=/api/v1

# News API (server-side only — get a key at https://newsapi.org)
NEWS_API_KEY=your-news-api-key

# OpenAI (server-side only — get a key at https://platform.openai.com)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Gemini (server-side only — get a key at https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key

# Groq (server-side only — get a key at https://console.groq.com)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# AI Fallback Configuration
AI_PROVIDER_ORDER=gemini,groq,openai
